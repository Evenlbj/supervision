<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{% block title %}NetSuper{% endblock %} — Supervision Réseau</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root {
  --bg:#06090f; --s1:#0c1220; --s2:#101828; --s3:#151f30; --s4:#1a2538;
  --bdr:rgba(255,255,255,.07); --bdr2:rgba(255,255,255,.04);
  --t1:#e2eaf8; --t2:#7a90b0; --t3:#3a5070; --t4:#1e3050;
  --blue:#2563eb; --blue2:#3b82f6; --blue3:#60a5fa;
  --green:#10b981; --red:#ef4444; --orange:#f97316;
  --yellow:#eab308; --purple:#8b5cf6; --cyan:#06b6d4;
  --sw:230px; --swc:56px; --th:52px;
  --r:8px; --rl:12px;
  --font:'Inter',sans-serif; --mono:'JetBrains Mono',monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;font-family:var(--font);font-size:13px;background:var(--bg);color:var(--t1);line-height:1.5;-webkit-font-smoothing:antialiased;}
a{text-decoration:none;color:inherit;}
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:2px;}

/* ── SIDEBAR ── */
.sidebar{position:fixed;top:0;left:0;width:var(--sw);height:100vh;background:var(--s1);border-right:1px solid var(--bdr);display:flex;flex-direction:column;z-index:200;transition:width .25s cubic-bezier(.4,0,.2,1);overflow:hidden;}
.sidebar.coll{width:var(--swc);}

.sb-brand{display:flex;align-items:center;gap:10px;padding:0 14px;height:var(--th);border-bottom:1px solid var(--bdr);flex-shrink:0;white-space:nowrap;overflow:hidden;}
.sb-logo{width:30px;height:30px;flex-shrink:0;border-radius:8px;background:linear-gradient(135deg,var(--blue),var(--blue2));display:flex;align-items:center;justify-content:center;box-shadow:0 4px 12px rgba(37,99,235,.4);}
.sb-logo svg{width:16px;height:16px;color:#fff;}
.sb-name{font-size:.92rem;font-weight:800;letter-spacing:-.4px;}
.sb-ver{font-family:var(--mono);font-size:.58rem;color:var(--t4);margin-left:auto;flex-shrink:0;}

.sb-toggle{position:absolute;top:16px;right:-11px;width:22px;height:22px;background:var(--s3);border:1px solid var(--bdr);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--t2);z-index:10;transition:all .2s;}
.sb-toggle:hover{background:var(--s4);color:var(--t1);}
.sb-toggle svg{width:11px;height:11px;transition:transform .25s;}
.sidebar.coll .sb-toggle svg{transform:rotate(180deg);}

.sb-nav{flex:1;padding:10px 8px;overflow-y:auto;overflow-x:hidden;}
.sb-section{margin-bottom:18px;}
.sb-lbl{display:block;font-size:.59rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--t4);padding:0 8px;margin-bottom:3px;white-space:nowrap;transition:opacity .2s;}
.sidebar.coll .sb-lbl{opacity:0;}

/* System status badge */
.sb-status{display:flex;align-items:center;gap:6px;margin:0 4px 14px;padding:7px 10px;background:rgba(16,185,129,.06);border:1px solid rgba(16,185,129,.15);border-radius:var(--r);}
.sb-status-dot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 6px rgba(16,185,129,.6);animation:pd 2s infinite;flex-shrink:0;}
@keyframes pd{0%,100%{opacity:1;}50%{opacity:.3;}}
.sb-status-txt{font-size:.67rem;font-weight:700;color:var(--green);white-space:nowrap;}
.sidebar.coll .sb-status-txt{display:none;}
.sidebar.coll .sb-status{justify-content:center;padding:8px;}

.sb-item{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:var(--r);color:var(--t2);font-size:.8rem;font-weight:500;cursor:pointer;transition:all .13s;white-space:nowrap;position:relative;overflow:hidden;}
.sb-item svg{width:15px;height:15px;flex-shrink:0;}
.sb-item:hover{background:rgba(255,255,255,.06);color:var(--t1);}
.sb-item.active{background:rgba(37,99,235,.12);color:var(--blue2);}
.sb-item.active::before{content:'';position:absolute;left:0;top:5px;bottom:5px;width:3px;border-radius:0 2px 2px 0;background:var(--blue2);}
.sb-bdg{margin-left:auto;flex-shrink:0;font-family:var(--mono);font-size:.58rem;font-weight:700;padding:1px 6px;border-radius:8px;background:rgba(239,68,68,.15);color:var(--red);}
.sidebar.coll .sb-txt,.sidebar.coll .sb-bdg{display:none;}
.sidebar.coll .sb-item{justify-content:center;padding:9px;}
.sidebar.coll .sb-item[data-tip]:hover::after{content:attr(data-tip);position:absolute;left:calc(var(--swc) + 8px);background:var(--s4);border:1px solid var(--bdr);border-radius:var(--r);padding:5px 11px;font-size:.73rem;color:var(--t1);white-space:nowrap;z-index:999;box-shadow:0 4px 16px rgba(0,0,0,.5);animation:tip .15s ease;}
@keyframes tip{from{opacity:0;transform:translateX(-4px);}to{opacity:1;transform:none;}}

.sb-footer{padding:10px;border-top:1px solid var(--bdr);display:flex;align-items:center;gap:9px;white-space:nowrap;overflow:hidden;flex-shrink:0;}
.sb-avatar{width:28px;height:28px;flex-shrink:0;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--purple));display:flex;align-items:center;justify-content:center;font-size:.68rem;font-weight:800;color:#fff;}
.sb-user{flex:1;overflow:hidden;}
.sb-uname{font-size:.77rem;font-weight:700;display:block;}
.sb-urole{font-size:.62rem;color:var(--t3);text-transform:capitalize;}
.sb-out{width:26px;height:26px;flex-shrink:0;display:flex;align-items:center;justify-content:center;border:none;background:none;cursor:pointer;color:var(--t3);border-radius:var(--r);transition:all .13s;}
.sb-out:hover{background:rgba(239,68,68,.1);color:var(--red);}
.sb-out svg{width:13px;height:13px;}

/* ── MAIN ── */
.main{margin-left:var(--sw);min-height:100vh;display:flex;flex-direction:column;transition:margin-left .25s cubic-bezier(.4,0,.2,1);}
.main.coll{margin-left:var(--swc);}

/* ── TOPBAR ── */
.topbar{position:sticky;top:0;z-index:100;height:var(--th);background:rgba(6,9,15,.9);backdrop-filter:blur(20px);border-bottom:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between;padding:0 20px;}
.tb-l,.tb-r{display:flex;align-items:center;gap:12px;}
.breadcrumb{display:flex;align-items:center;gap:5px;font-size:.75rem;color:var(--t2);}
.breadcrumb .sep{color:var(--t4);}
.breadcrumb .cur{color:var(--t1);font-weight:600;}
.tb-live{display:flex;align-items:center;gap:5px;font-size:.67rem;font-weight:700;color:var(--green);background:rgba(16,185,129,.07);border:1px solid rgba(16,185,129,.18);padding:3px 10px;border-radius:20px;}
.pulse{width:5px;height:5px;border-radius:50%;background:var(--green);animation:pd 2s infinite;}
.tb-clock{font-family:var(--mono);font-size:.68rem;color:var(--t3);}
.tb-logout{display:flex;align-items:center;gap:5px;padding:5px 12px;border-radius:var(--r);background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.18);color:#f87171;font-size:.72rem;font-weight:700;transition:all .15s;}
.tb-logout:hover{background:rgba(239,68,68,.18);}
.tb-logout svg{width:13px;height:13px;}

.content{flex:1;padding:18px 20px;display:flex;flex-direction:column;gap:14px;}

/* ── SHARED ── */
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 13px;border-radius:var(--r);font-family:var(--font);font-size:.75rem;font-weight:700;cursor:pointer;border:none;transition:all .17s;white-space:nowrap;}
.btn svg{width:12px;height:12px;}
.btn-p{background:linear-gradient(135deg,var(--blue),#1d4ed8);color:#fff;box-shadow:0 2px 10px rgba(37,99,235,.3);}
.btn-p:hover{box-shadow:0 4px 18px rgba(37,99,235,.45);transform:translateY(-1px);}
.btn-o{background:linear-gradient(135deg,var(--orange),#ea580c);color:#fff;box-shadow:0 2px 10px rgba(249,115,22,.25);}
.btn-o:hover{box-shadow:0 4px 18px rgba(249,115,22,.4);transform:translateY(-1px);}
.btn-g{background:transparent;color:var(--t2);border:1px solid var(--bdr);}
.btn-g:hover{background:rgba(255,255,255,.05);color:var(--t1);}
.btn-r{background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.18);}

.inp{background:var(--s2);border:1px solid var(--bdr);border-radius:var(--r);padding:7px 11px;color:var(--t1);font-family:var(--font);font-size:.76rem;outline:none;transition:border-color .18s;}
.inp:focus{border-color:var(--blue2);box-shadow:0 0 0 2px rgba(59,130,246,.1);}
.inp::placeholder{color:var(--t4);}
select.inp{cursor:pointer;}

/* ── Cards & Tables ── */
.card{background:var(--s2);border:1px solid var(--bdr);border-radius:var(--rl);overflow:hidden;}
.tbl-card{background:var(--s2);border:1px solid var(--bdr);border-radius:var(--rl);overflow:hidden;}
.tbl-hd{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(--bdr);}
.tbl-hd-l{display:flex;align-items:center;gap:7px;}
.tbl-hd-l svg{width:13px;height:13px;color:var(--t3);}
.tbl-ttl{font-size:.78rem;font-weight:700;}
.tbl-lnk{font-size:.72rem;color:var(--blue2);}
.tbl-lnk:hover{color:var(--blue3);}
table{width:100%;border-collapse:collapse;font-size:.76rem;}
thead th{background:rgba(255,255,255,.02);border-bottom:1px solid var(--bdr);padding:7px 14px;text-align:left;font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--t3);white-space:nowrap;}
tbody td{padding:9px 14px;border-bottom:1px solid var(--bdr2);vertical-align:middle;}
tbody tr:last-child td{border-bottom:none;}
tbody tr:hover td{background:rgba(255,255,255,.02);}
.td-m{font-family:var(--mono);font-size:.71rem;color:var(--t2);}

/* ── Badges ── */
.tag{display:inline-flex;align-items:center;padding:2px 7px;border-radius:4px;font-size:.6rem;font-weight:700;text-transform:uppercase;white-space:nowrap;}
.tc{background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.18);}
.th{background:rgba(249,115,22,.1);color:#fb923c;border:1px solid rgba(249,115,22,.18);}
.tm{background:rgba(234,179,8,.1);color:#facc15;border:1px solid rgba(234,179,8,.18);}
.tl{background:rgba(16,185,129,.08);color:#34d399;border:1px solid rgba(16,185,129,.14);}
.s-open{background:rgba(239,68,68,.08);color:#f87171;border:1px solid rgba(239,68,68,.14);}
.s-prog{background:rgba(234,179,8,.08);color:#facc15;border:1px solid rgba(234,179,8,.14);}
.s-patch{background:rgba(16,185,129,.07);color:#34d399;border:1px solid rgba(16,185,129,.12);}
.s-comp{background:rgba(16,185,129,.07);color:#34d399;border:1px solid rgba(16,185,129,.12);}
.s-run{background:rgba(37,99,235,.1);color:var(--blue2);border:1px solid rgba(37,99,235,.18);}
.s-fail{background:rgba(239,68,68,.08);color:#f87171;border:1px solid rgba(239,68,68,.14);}

.cve-c{font-family:var(--mono);font-size:.7rem;color:var(--blue3);background:rgba(59,130,246,.08);padding:2px 6px;border-radius:3px;}
.host-c{font-family:var(--mono);font-size:.7rem;background:rgba(255,255,255,.05);padding:2px 6px;border-radius:3px;}
.proto-c{font-family:var(--mono);font-size:.6rem;font-weight:700;padding:1px 6px;border-radius:3px;background:rgba(139,92,246,.1);color:#a78bfa;border:1px solid rgba(139,92,246,.15);}
.cvss-r{display:flex;align-items:center;gap:6px;}
.cvss-t{flex:1;max-width:65px;height:4px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden;}
.cvss-f{height:100%;border-radius:2px;}
.cvss-v{font-family:var(--mono);font-size:.7rem;font-weight:700;width:26px;}
.np{font-family:var(--mono);font-size:.71rem;font-weight:600;padding:2px 8px;border-radius:4px;}
.np-d{background:rgba(239,68,68,.1);color:#f87171;}
.np-w{background:rgba(249,115,22,.1);color:#fb923c;}
.np-g{background:rgba(16,185,129,.1);color:#34d399;}
.np-n{background:rgba(255,255,255,.05);color:var(--t1);}
.tool-t{display:inline;font-family:var(--mono);font-size:.65rem;font-weight:700;padding:2px 7px;border-radius:4px;}
.tn{background:rgba(37,99,235,.1);color:var(--blue2);border:1px solid rgba(37,99,235,.18);}
.to{background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.18);}
.tns{background:rgba(249,115,22,.1);color:#fb923c;border:1px solid rgba(249,115,22,.18);}
.tk{background:rgba(139,92,246,.1);color:#a78bfa;border:1px solid rgba(139,92,246,.18);}

/* ── KPI ── */
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}
.kpi{background:var(--s2);border:1px solid var(--bdr);border-radius:var(--rl);padding:14px 16px;display:flex;align-items:center;gap:12px;position:relative;overflow:hidden;transition:transform .18s,box-shadow .18s;}
.kpi:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,.5);}
.kpi::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;border-radius:var(--rl) var(--rl) 0 0;}
.kpi-b::after{background:linear-gradient(90deg,var(--blue),var(--blue2));}
.kpi-r::after{background:linear-gradient(90deg,var(--red),#f87171);}
.kpi-o::after{background:linear-gradient(90deg,var(--orange),#fb923c);}
.kpi-g::after{background:linear-gradient(90deg,var(--green),#34d399);}
.kpi-ico{width:38px;height:38px;flex-shrink:0;border-radius:var(--r);display:flex;align-items:center;justify-content:center;}
.kpi-b .kpi-ico{background:rgba(37,99,235,.12);color:var(--blue2);}
.kpi-r .kpi-ico{background:rgba(239,68,68,.12);color:#f87171;}
.kpi-o .kpi-ico{background:rgba(249,115,22,.12);color:#fb923c;}
.kpi-g .kpi-ico{background:rgba(16,185,129,.12);color:#34d399;}
.kpi-ico svg{width:18px;height:18px;}
.kpi-body{flex:1;}
.kpi-val{display:block;font-family:var(--mono);font-size:1.4rem;font-weight:700;line-height:1;color:var(--t1);}
.kpi-lbl{display:block;font-size:.67rem;color:var(--t2);margin-top:3px;}
.kpi-sub{position:absolute;bottom:10px;right:12px;font-size:.62rem;font-weight:700;border-radius:8px;padding:1px 7px;}
.kpi-b .kpi-sub{background:rgba(37,99,235,.1);color:var(--blue2);}
.kpi-r .kpi-sub{background:rgba(239,68,68,.1);color:#f87171;}
.kpi-o .kpi-sub{background:rgba(249,115,22,.1);color:#fb923c;}
.kpi-g .kpi-sub{background:rgba(16,185,129,.1);color:#34d399;}

/* ── Host cards ── */
.host-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(178px,1fr));gap:11px;}
.host-card{background:var(--s2);border:1px solid var(--bdr);border-radius:var(--rl);padding:14px;display:flex;flex-direction:column;gap:9px;transition:transform .18s,box-shadow .18s;cursor:pointer;}
.host-card:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.4);border-color:rgba(255,255,255,.12);}
.hc-top{display:flex;align-items:center;justify-content:space-between;}
.hc-dot{width:8px;height:8px;border-radius:50%;}
.up .hc-dot{background:var(--green);box-shadow:0 0 6px rgba(16,185,129,.6);}
.down .hc-dot{background:var(--red);}
.warning .hc-dot{background:var(--yellow);}
.unknown .hc-dot{background:var(--t3);}
.hc-cat{font-size:.58rem;font-weight:700;padding:2px 6px;border-radius:8px;background:rgba(255,255,255,.04);border:1px solid var(--bdr);color:var(--t3);text-transform:capitalize;}
.hc-ico{width:40px;height:40px;background:rgba(255,255,255,.04);border:1px solid var(--bdr);border-radius:var(--r);display:flex;align-items:center;justify-content:center;color:var(--t3);}
.hc-ico svg{width:22px;height:22px;}
.up .hc-ico{border-color:rgba(16,185,129,.2);color:var(--green);}
.hc-info{display:flex;flex-direction:column;gap:2px;}
.hc-name{font-size:.8rem;font-weight:700;color:var(--t1);}
.hc-ip{font-family:var(--mono);font-size:.68rem;color:var(--blue2);}
.hc-os{font-size:.65rem;color:var(--t3);}
.hc-ft{display:flex;align-items:center;justify-content:space-between;padding-top:7px;border-top:1px solid var(--bdr2);}
.hc-st{font-size:.62rem;font-weight:700;text-transform:uppercase;}
.up .hc-st{color:var(--green);}
.down .hc-st{color:var(--red);}
.warning .hc-st{color:var(--yellow);}
.unknown .hc-st{color:var(--t3);}
.hc-vul{font-size:.62rem;font-weight:700;padding:1px 6px;border-radius:8px;}
.hc-vul.d{background:rgba(239,68,68,.12);color:#f87171;}
.hc-vul.w{background:rgba(249,115,22,.1);color:#fb923c;}
.hc-vul.g{background:rgba(16,185,129,.1);color:#34d399;}

/* ── Events ── */
.ev-feed{max-height:360px;overflow-y:auto;}
.ev-item{display:flex;align-items:flex-start;gap:9px;padding:8px 16px;border-bottom:1px solid var(--bdr2);transition:background .1s;}
.ev-item:last-child{border-bottom:none;}
.ev-item:hover{background:rgba(255,255,255,.02);}
.ev-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-top:5px;}
.ev-critical .ev-dot{background:var(--red);box-shadow:0 0 5px rgba(239,68,68,.5);}
.ev-high .ev-dot{background:var(--orange);}
.ev-medium .ev-dot{background:var(--yellow);}
.ev-low .ev-dot{background:var(--green);}
.ev-body{flex:1;display:flex;flex-direction:column;gap:1px;}
.ev-type{font-size:.73rem;font-weight:700;}
.ev-msg{font-size:.68rem;color:var(--t2);}
.ev-meta{font-family:var(--mono);font-size:.6rem;color:var(--t3);}
.ev-time{font-family:var(--mono);font-size:.62rem;color:var(--t3);flex-shrink:0;}

.psm{width:5px;height:5px;border-radius:50%;background:currentColor;animation:pd 1.5s infinite;display:inline-block;}

@media(max-width:1280px){.kpi-row{grid-template-columns:repeat(2,1fr);}}
@media(max-width:768px){:root{--sw:var(--swc);}.sidebar{width:var(--swc);}.main{margin-left:var(--swc);}}
</style>
{% block head %}{% endblock %}
</head>
<body>

<aside class="sidebar" id="sb">
  <div class="sb-brand">
    <div class="sb-logo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
    </div>
    <span class="sb-name">NetSuper</span>
    <span class="sb-ver">v2.5</span>
  </div>

  <button class="sb-toggle" onclick="toggleSb()">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15,18 9,12 15,6"/></svg>
  </button>

  <nav class="sb-nav">
    <div class="sb-status">
      <div class="sb-status-dot"></div>
      <span class="sb-status-txt">Système opérationnel</span>
    </div>

    <div class="sb-section">
      <span class="sb-lbl">Principal</span>

      <a href="{{ url_for('dashboard') }}"
         class="sb-item {% if request.endpoint=='dashboard' %}active{% endif %}"
         data-tip="Tableau de bord">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7" rx="1.5"/>
          <rect x="14" y="3" width="7" height="7" rx="1.5"/>
          <rect x="14" y="14" width="7" height="7" rx="1.5"/>
          <rect x="3" y="14" width="7" height="7" rx="1.5"/>
        </svg>
        <span class="sb-txt">Tableau de bord</span>
      </a>

      <a href="{{ url_for('hosts_page') }}"
         class="sb-item {% if request.endpoint=='hosts_page' %}active{% endif %}"
         data-tip="Hôtes réseau">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/>
        </svg>
        <span class="sb-txt">Hôtes réseau</span>
      </a>

      <a href="{{ url_for('vulns_page') }}"
         class="sb-item {% if request.endpoint=='vulns_page' %}active{% endif %}"
         data-tip="Vulnérabilités">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <line x1="12" y1="9" x2="12" y2="13"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <span class="sb-txt">Vulnérabilités</span>
        <span class="sb-bdg" id="nav-vuln">—</span>
      </a>
    </div>

    <div class="sb-section">
      <span class="sb-lbl">Surveillance</span>

      <a href="{{ url_for('events_page') }}"
         class="sb-item {% if request.endpoint=='events_page' %}active{% endif %}"
         data-tip="Événements réseau">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
        </svg>
        <span class="sb-txt">Événements</span>
      </a>

      <a href="{{ url_for('scans_page') }}"
         class="sb-item {% if request.endpoint=='scans_page' %}active{% endif %}"
         data-tip="Scanner réseau">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <span class="sb-txt">Scanner</span>
      </a>

      <a href="{{ url_for('stats_page') }}"
         class="sb-item {% if request.endpoint=='stats_page' %}active{% endif %}"
         data-tip="Statistiques">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 20V10m-6 10V4M6 20v-6"/>
        </svg>
        <span class="sb-txt">Statistiques</span>
      </a>
    <a href="{{ url_for('esp32_page') }}"
       class="sb-item {% if request.endpoint == 'esp32_page' %}active{% endif %}"
       title="Sonde ESP32">
      <svg class="sb-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="4" y="4" width="16" height="16" rx="2"/>
        <rect x="9" y="9" width="6" height="6"/>
        <line x1="9" y1="2" x2="9" y2="4"/><line x1="15" y1="2" x2="15" y2="4"/>
        <line x1="9" y1="20" x2="9" y2="22"/><line x1="15" y1="20" x2="15" y2="22"/>
        <line x1="2" y1="9" x2="4" y2="9"/><line x1="2" y1="15" x2="4" y2="15"/>
        <line x1="20" y1="9" x2="22" y2="9"/><line x1="20" y1="15" x2="22" y2="15"/>
      </svg>
      <span class="sb-label">Sonde ESP32</span>
    </a>
    </div>
  </nav>

  <div class="sb-footer">
    <a href="{{ url_for('account') }}" style="text-decoration:none;display:flex;align-items:center;gap:9px;flex:1;overflow:hidden;" title="Paramètres du compte">
      <div class="sb-avatar">{{ (username or 'A')[0]|upper }}</div>
      <div class="sb-user">
        <span class="sb-uname">{{ username or 'admin' }}</span>
        <span class="sb-urole">{{ role or 'admin' }}</span>
      </div>
    </a>
    <a href="{{ url_for('logout') }}" class="sb-out" title="Déconnexion">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
        <polyline points="16,17 21,12 16,7"/>
        <line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
    </a>
  </div>
</aside>

<div class="main" id="main">
  <header class="topbar">
    <div class="tb-l">
      <div class="breadcrumb">
        <span>NetSuper</span>
        <span class="sep">›</span>
        <span class="cur">{% block breadcrumb %}Dashboard{% endblock %}</span>
      </div>
    </div>
    <div class="tb-r">
      <div class="tb-live"><div class="pulse"></div>Live</div>
      <div class="tb-clock" id="clk"></div>
      <a href="{{ url_for('logout') }}" class="tb-logout">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
          <polyline points="16,17 21,12 16,7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
        Déconnexion
      </a>
    </div>
  </header>

  <main class="content">{% block content %}{% endblock %}</main>
</div>

<script>
// Clock
const clk = document.getElementById('clk');
function tick() {
  const n = new Date();
  clk.textContent = n.toLocaleDateString('fr-FR',{day:'2-digit',month:'2-digit',year:'numeric'})
    + ' ' + n.toLocaleTimeString('fr-FR');
}
setInterval(tick, 1000); tick();

// Sidebar toggle
function toggleSb() {
  document.getElementById('sb').classList.toggle('coll');
  document.getElementById('main').classList.toggle('coll');
}

// CVE badge
fetch('/api/stats/cvss')
  .then(r => r.json())
  .then(d => {
    const t = d.reduce((s,x) => s + x.count, 0);
    const el = document.getElementById('nav-vuln');
    if (el) el.textContent = t;
  }).catch(() => {});
</script>
{% block scripts %}{% endblock %}
</body>
</html>
